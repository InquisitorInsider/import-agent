# ============================================================
# import-agent — gateway de clientes desde la base DBF antigua.
# Casi todo se configura desde el PANEL WEB:  http://IP_DEL_HOST:8000
# Estos valores son solo la SEMILLA de la primera ejecución.
# ============================================================

# --- Protección del panel web (opcional, recomendado) ---
ADMIN_USER=admin
ADMIN_PASSWORD=                 # si lo defines, el panel pedirá usuario/clave

# --- Token para que el bot consulte /clientes/buscar (opcional) ---
LOOKUP_TOKEN=                   # si lo defines, el bot debe mandar Authorization: Bearer

# --- Origen de los DBF ---
DBF_SOURCE_TYPE=smb             # smb (carpeta compartida) o local (volumen montado)
# SMB:
SMB_HOST=                       # IP del PC/servidor que comparte la carpeta
SMB_SHARE=                      # nombre EXACTO del recurso compartido
SMB_PATH=                       # subcarpeta dentro del recurso (opcional)
SMB_USER=                       # usuario (vacío = comparte abierta)
SMB_PASS=
SMB_DOMAIN=WORKGROUP
#SMB_IP=192.168.1.50            # IP explícita si el nombre no resuelve
# LOCAL (si DBF_SOURCE_TYPE=local):
#DBF_LOCAL_DIR=/dbf

# --- Nombres de los archivos DBF ---
CLIENTES_FILE=clientesdomicilio.dbf
DIRECCIONES_FILE=direccionesdomicilio.dbf

# --- Lectura / validación ---
DBF_ENCODING=cp1252             # FoxPro Windows ANSI (acentos y ñ correctos)
PHONE_DIGITS=9                  # un idcliente válido = 9 dígitos numéricos
COUNTRY_CODE=51                 # prefijo país a quitar del celular_real del bot

# --- Sincronización con el bot (opcional) ---
BOT_DB_PATH=                    # ruta del SQLite del bot montado, p.ej. /bot/pedidos.db
